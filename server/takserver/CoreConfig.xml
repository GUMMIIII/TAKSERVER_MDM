<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  KOMMS – TAKServer Core Configuration Template (5.7 format)
  Placeholders replaced by setup_tak.sh at install time:
    KOMMS_TAK_DB_USER      → PostgreSQL username
    KOMMS_TAK_DB_PASS      → PostgreSQL password
    KOMMS_CERT_PASS        → JKS keystore/truststore password
    KOMMS_LDAP_ADMIN_PASS  → LLDAP admin password
    KOMMS_LDAP_BASE_DN     → LDAP base DN (e.g. dc=komms,dc=local)

  5.7 differences from 5.3:
  - clientAuth uses enum strings: NONE / NEED / WANT  (not false / true)
  - DB config lives inside <repository><connection url="..."/></repository>
    (the old 5.3 <db connectionString="..."> element is gone)
  - connectionPoolAutoSize="false" numDbConnections="16" required when
    repository enable="false" — otherwise DataSourceUtils computes pool=1
  - LDAP uses userstring="{username},..." (not userDN="%s,...")
  - enableWebtak="true" on connector grants ROLE_WEBTAK via RolePortUserServiceWrapper
-->
<Configuration>

    <network multicastTTL="5" version="3">

        <!-- TLS input for ATAK / WinTAK clients (port 8089) -->
        <input _name="stdssl"
               auth="x509"
               binaryPayloadWebsocketPath="/takproto/1"
               protocol="tls"
               port="8089"
               coreVersion="2"/>

        <!-- HTTPS connector – nginx proxies tak.DOMAIN here (port 8443) -->
        <!-- clientAuth NONE: no client cert required.                    -->
        <!-- enableWebtak grants ROLE_WEBTAK for /webtak/** access.       -->
        <connector port="8443"
                   _name="https"
                   clientAuth="WANT"
                   enableWebtak="true"
                   keystoreFile="/opt/tak/certs/files/takserver.jks"
                   keystorePass="KOMMS_CERT_PASS"
                   truststoreFile="/opt/tak/certs/files/truststore-root.jks"
                   truststorePass="KOMMS_CERT_PASS"
                   keyManagerType="SunX509"/>

        <!-- Certificate enrollment connector (port 8444, mTLS) -->
        <connector port="8444"
                   _name="https_cert"
                   clientAuth="NEED"
                   keystoreFile="/opt/tak/certs/files/takserver.jks"
                   keystorePass="KOMMS_CERT_PASS"
                   truststoreFile="/opt/tak/certs/files/fed-truststore.jks"
                   truststorePass="KOMMS_CERT_PASS"
                   keyManagerType="SunX509"/>

        <!-- Certificate-based HTTPS without client auth (port 8446)      -->
        <!-- Primary WebTAK port: has ROLE_NO_CLIENT_CERT (portRoleMap)   -->
        <!-- + ROLE_WEBTAK (enableWebtak) + /login /oauth/token access.   -->
        <connector port="8446"
                   _name="cert_https"
                   clientAuth="NONE"
                   enableWebtak="true"
                   keystoreFile="/opt/tak/certs/files/takserver.jks"
                   keystorePass="KOMMS_CERT_PASS"
                   truststoreFile="/opt/tak/certs/files/truststore-root.jks"
                   truststorePass="KOMMS_CERT_PASS"
                   keyManagerType="SunX509"/>

    </network>

    <!--
      Authentication:
        - ATAK/WinTAK clients: x509 certificate
        - WebTAK / admin UI:   LDAP via LLDAP (SSO)
        - OAuth2 bearer token: Spring Authorization Server (password grant)
    -->
    <auth x509groups="true" x509addAnonymous="false" default="ldap">
        <ldap url="ldap://lldap:3890"
              userstring="uid={username},ou=people,KOMMS_LDAP_BASE_DN"
              style="DS"
              serviceAccountDN="uid=admin,ou=people,KOMMS_LDAP_BASE_DN"
              serviceAccountCredential="KOMMS_LDAP_ADMIN_PASS"
              groupObjectClass="groupOfUniqueNames"
              groupBaseRDN="ou=groups,KOMMS_LDAP_BASE_DN"
              userBaseRDN="ou=people,KOMMS_LDAP_BASE_DN"/>
        <File/>
        <oauth useTakServerLoginPage="true">
            <client clientId="tak-webtak" scope="openid"
                    authorizedGrantTypes="password,refresh_token" autoapprove="true"/>
        </oauth>
    </auth>

    <submission ignoreStaleMessages="false" validateXml="false"/>
    <subscription reloadPersistent="true"/>

    <!--
      Repository: file storage disabled (use Nextcloud instead).
      connectionPoolAutoSize="false" + numDbConnections="16" bypasses the
      auto-size formula that reads max_connections from Postgres — which
      silently returns 0 when enable="false", causing pool size = 1.
    -->
    <repository enable="false"
                connectionPoolAutoSize="false"
                numDbConnections="16">
        <connection url="jdbc:postgresql://postgres:5432/tak"
                    username="KOMMS_TAK_DB_USER"
                    password="KOMMS_TAK_DB_PASS"/>
    </repository>

    <dissemination smartRetry="false"
                   numWorkerThreads="4"
                   queueDepth="1000"
                   selfStop="false"/>

    <buffer latestSA="true"/>

    <GeospatialFilter enable="false"/>

    <rateLimiter/>

    <deliveryRateLimiter>
        <rule threshold="500"  maxRatePerClientPerInterval="50" interval="1"/>
        <rule threshold="2000" maxRatePerClientPerInterval="30" interval="1"/>
    </deliveryRateLimiter>

    <security>
        <tls keystore="JKS"
             keystoreFile="/opt/tak/certs/files/takserver.jks"
             keystorePass="KOMMS_CERT_PASS"
             truststore="JKS"
             truststoreFile="/opt/tak/certs/files/truststore-root.jks"
             truststorePass="KOMMS_CERT_PASS"
             context="TLSv1.2"
             keyManagerType="SunX509"/>
    </security>

    <vbm enable="false"/>
    <cluster enable="true"/>

    <!-- Federation disabled for closed deployment -->
    <federation v1Enabled="false"
                v2Enabled="false"
                enableMissionFederation="false"
                allowFederatedDelete="true"
                missionFederationDisruptionTolerance="43200">
        <tls keystore="JKS"
             keystoreFile="/opt/tak/certs/files/takserver.jks"
             keystorePass="KOMMS_CERT_PASS"
             truststore="JKS"
             truststoreFile="/opt/tak/certs/files/fed-truststore.jks"
             truststorePass="KOMMS_CERT_PASS"
             context="TLSv1.3"
             keyManagerType="SunX509"/>
    </federation>

    <streamingBroker enable="true"/>

    <repeater enable="true" periodMillis="3000">
        <rule type="GeoFenceBreach"/>
        <rule type="RingFenceBreached"/>
        <rule type="911Alert"/>
        <rule type="Mayday"/>
    </repeater>

</Configuration>

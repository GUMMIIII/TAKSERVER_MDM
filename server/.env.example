# ─────────────────────────────────────────────────────────────────────────────
#  TAKSERVER_MDM Platform – Environment Configuration Template
#
#  Produktion:   install.sh erzeugt .env automatisch aus deinen Eingaben.
#  Lokaler Test: cp .env.example .env  →  Werte eintragen  →  docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Pfade ─────────────────────────────────────────────────────────────────────
# Persistente Daten (Configs, Secrets, User-Files) — getrennt vom Code-Repo.
DATA_DIR=/opt/komms-data

# ── Server ────────────────────────────────────────────────────────────────────
# Öffentliche Basis-Domain. Subdomains werden automatisch abgeleitet:
#   auth., cloud., element., matrix., mdm., mumble., tak., ldap., collabora.
DOMAIN=komms.example.com

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Echte E-Mail erforderlich (Cert-Expiry-Notices).
LETSENCRYPT_EMAIL=admin@example.com

# ── Datenbank (PostgreSQL) ────────────────────────────────────────────────────
DB_USER=komms
DB_PASS=CHANGE_ME_STRONG_PASSWORD_MIN12

# ── Headwind MDM ──────────────────────────────────────────────────────────────
HMDM_URL=https://mdm.komms.example.com
HMDM_ADMIN_EMAIL=admin@komms.local
HMDM_ADMIN_PASS=CHANGE_ME_MDM_PASS
HEADWIND_DOMAIN=mdm.komms.example.com

# ── Nextcloud ─────────────────────────────────────────────────────────────────
NC_ADMIN=admin
NC_PASS=CHANGE_ME_NC_PASS
NC_TRUSTED_DOMAIN=cloud.komms.example.com

# ── Matrix / Synapse ──────────────────────────────────────────────────────────
# Matrix-Nutzer-IDs: @user:DOMAIN — immer die Basis-Domain, nie die Subdomain.
MATRIX_DOMAIN=komms.example.com
MATRIX_PUBLIC_BASEURL=https://matrix.komms.example.com
# Mit openssl rand -hex 32 generieren:
MATRIX_MACAROON_SECRET=CHANGE_ME_MACAROON_SECRET
MATRIX_FORM_SECRET=CHANGE_ME_FORM_SECRET
MATRIX_REGISTRATION_SHARED_SECRET=CHANGE_ME_REGISTRATION_SECRET

# ── SSO / LDAP (LLDAP) ───────────────────────────────────────────────────────
LDAP_BASE_DN=dc=komms,dc=local
LDAP_ADMIN_PASS=CHANGE_ME_LDAP_ADMIN_PASS
LLDAP_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Authelia (SSO Gateway) ────────────────────────────────────────────────────
# Alle mit: openssl rand -hex 32
AUTHELIA_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
AUTHELIA_SESSION_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
AUTHELIA_OIDC_HMAC_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
NEXTCLOUD_OIDC_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
SYNAPSE_OIDC_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Mumble ────────────────────────────────────────────────────────────────────
MUMBLE_SERVER_NAME=KOMMS Voice
MUMBLE_SUPERUSER_PASS=CHANGE_ME_MUMBLE_SUPERUSER_PASS
MUMBLE_SERVER_PASS=CHANGE_ME_MUMBLE_JOIN_PASS

# ── OpenVPN ───────────────────────────────────────────────────────────────────
VPN_HOST=komms.example.com
VPN_PORT=1194
VPN_PROTO=udp
VPN_SUBNET=10.8.0.0
VPN_MASK=255.255.255.0

# ── Collabora Online (CODE) ───────────────────────────────────────────────────
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASS=CHANGE_ME_COLLABORA_PASS

# ── TAKServer ─────────────────────────────────────────────────────────────────
TAK_DOMAIN=tak.komms.example.com
TAK_CERT_PASS=atakatak
# Wird von setup_tak.sh nach dem Image-Build/Load gesetzt (z.B. takserver/takserver:5.7-RELEASE-32).
# Leer lassen — docker compose up takserver schlägt absichtlich fehl, bis setup_tak.sh gelaufen ist.
TAK_IMAGE=

# ── Zertifikatsfelder ─────────────────────────────────────────────────────────
CERT_COUNTRY=DE
CERT_STATE=Bayern
CERT_CITY=Berlin
CERT_ORG=KOMMS
CERT_UNIT=Ops
